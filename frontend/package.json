{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run -c test/unit/vitest.config.ts",
    "test:watch": "vitest -c test/unit/vitest.config.ts",
    "test:e2e": "playwright test test/e2e --config test/e2e/playwright.config.ts",
    "test:frontend": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
"@testing-library/vue": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
